test/test_world_loads.o: test/test_world_loads.cpp.o
.PHONY : test/test_world_loads.o

# target to build an object file
test/test_world_loads.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_world_loads.dir/build.make CMakeFiles/test_world_loads.dir/test/test_world_loads.cpp.o
.PHONY : test/test_world_loads.cpp.o

test/test_world_loads.i: test/test_world_loads.cpp.i
.PHONY : test/test_world_loads.i

# target to preprocess a source file
test/test_world_loads.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_world_loads.dir/build.make CMakeFiles/test_world_loads.dir/test/test_world_loads.cpp.i
.PHONY : test/test_world_loads.cpp.i

test/test_world_loads.s: test/test_world_loads.cpp.s
.PHONY : test/test_world_loads.s

# target to generate assembly for a file
test/test_world_loads.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_world_loads.dir/build.make CMakeFiles/test_world_loads.dir/test/test_world_loads.cpp.s
.PHONY : test/test_world_loads.cpp.s

